# Enforce LF line endings for shell scripts (required on Linux)
*.sh        text eol=lf
*.py        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.txt       text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.gitignore text eol=lf

# Binary files — no line ending conversion
*.pth       binary
*.bin       binary
*.ply       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
